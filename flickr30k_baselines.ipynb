 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Flickr30K Multimodal Baselines: CLIP and BLIP\n",
    "\n",
    "This notebook contains two baseline evaluations for the Flickr30K dataset:\n",
    "1. **CLIP Baseline**: Evaluates text-to-image retrieval performance (Recall@1, Recall@5, MRR).\n",
    "2. **BLIP Baseline**: Evaluates image captioning performance (BLEU-4, ROUGE-L, METEOR, BERTScore).\n",
    "\n",
    "Developed for research on multimodal retrieval and generation."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Setup and Installations\n",
    "\n",
    "We install the necessary libraries. Note that we pin `datasets<3.0.0` to maintain support for dataset scripts (like `flickr30k.py`) which were deprecated in version 3.0.0+."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install -q transformers \"datasets<3.0.0\" pillow tqdm nltk rouge-score bert-score\n",
    "\n",
    "import nltk\n",
    "nltk.download('punkt_tab')\n",
    "nltk.download('wordnet')\n",
    "nltk.download('omw-1.4')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Shared Imports and Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import numpy as np\n",
    "import json\n",
    "import os\n",
    "from tqdm.auto import tqdm\n",
    "from datasets import load_dataset\n",
    "from PIL import Image\n",
    "\n",
    "# Ensure remote code is trusted for dataset scripts\n",
    "os.environ[\"HF_DATASETS_TRUST_REMOTE_CODE\"] = \"1\"\n",
    "\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "print(f\"Using device: {device}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. CLIP Baseline: Text-to-Image Retrieval"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from transformers import CLIPProcessor, CLIPModel\n",
    "\n",
    "def evaluate_clip_baseline():\n",
    "    model = CLIPModel.from_pretrained(\n",
    "        \"openai/clip-vit-base-patch32\", torch_dtype=torch.float16 if device == \"cuda\" else torch.float32\n",
    "    ).to(device)\n",
    "    processor = CLIPProcessor.from_pretrained(\"openai/clip-vit-base-patch32\")\n",
    "    model.eval()\n",
    "\n",
    "    print(\"Loading Flickr30K dataset...\")\n",
    "    ds = load_dataset(\"nlphuji/flickr30k\", split=\"test\", trust_remote_code=True)\n",
    "    num_images = len(ds)\n",
    "    \n",
    "    captions = []\n",
    "    caption_to_image_idx = []\n",
    "    for i in range(num_images):\n",
    "        cap_field = ds[i][\"caption\"]\n",
    "        cap_list = json.loads(cap_field) if isinstance(cap_field, str) else cap_field\n",
    "        for cap in cap_list:\n",
    "            captions.append(cap)\n",
    "            caption_to_image_idx.append(i)\n",
    "    \n",
    "    num_captions = len(captions)\n",
    "    print(f\"Unique images: {num_images}, Total captions: {num_captions}\")\n",
    "\n",
    "    print(\"Encoding images...\")\n",
    "    batch_size = 128\n",
    "    all_image_embeds = []\n",
    "    for start in tqdm(range(0, num_images, batch_size)):\n",
    "        end = min(start + batch_size, num_images)\n",
    "        batch_images = [ds[j][\"image\"].convert(\"RGB\") for j in range(start, end)]\n",
    "        inputs = processor(images=batch_images, return_tensors=\"pt\", padding=True).to(device)\n",
    "        with torch.no_grad():\n",
    "            out = model.get_image_features(**inputs)\n",
    "            embeds = out / out.norm(dim=-1, keepdim=True)\n",
    "        all_image_embeds.append(embeds.float().cpu())\n",
    "    image_embeds = torch.cat(all_image_embeds, dim=0)\n",
    "\n",
    "    print(\"Encoding captions...\")\n",
    "    all_text_embeds = []\n",
    "    for start in tqdm(range(0, num_captions, batch_size)):\n",
    "        end = min(start + batch_size, num_captions)\n",
    "        batch_texts = captions[start:end]\n",
    "        inputs = processor(text=batch_texts, return_tensors=\"pt\", padding=True, truncation=True).to(device)\n",
    "        with torch.no_grad():\n",
    "            out = model.get_text_features(**inputs)\n",
    "            embeds = out / out.norm(dim=-1, keepdim=True)\n",
    "        all_text_embeds.append(embeds.float().cpu())\n",
    "    text_embeds = torch.cat(all_text_embeds, dim=0)\n",
    "\n",
    "    print(\"Computing retrieval metrics...\")\n",
    "    caption_to_image_idx_t = torch.tensor(caption_to_image_idx, dtype=torch.long)\n",
    "    ranks = []\n",
    "    eval_batch = 512\n",
    "    for start in tqdm(range(0, num_captions, eval_batch)):\n",
    "        end = min(start + eval_batch, num_captions)\n",
    "        sims = text_embeds[start:end] @ image_embeds.T\n",
    "        sorted_indices = sims.argsort(dim=-1, descending=True)\n",
    "        gt = caption_to_image_idx_t[start:end].unsqueeze(1)\n",
    "        batch_ranks = (sorted_indices == gt).nonzero(as_tuple=True)[1] + 1\n",
    "        ranks.append(batch_ranks)\n",
    "\n",
    "    ranks = torch.cat(ranks).numpy()\n",
    "    recall_at_1 = (ranks <= 1).mean() * 100\n",
    "    recall_at_5 = (ranks <= 5).mean() * 100\n",
    "    mrr = (1.0 / ranks).mean()\n",
    "\n",
    "    print(f\"\\n=== CLIP Retrieval Results ===\")\n",
    "    print(f\"Recall@1: {recall_at_1:.2f}%\")\n",
    "    print(f\"Recall@5: {recall_at_5:.2f}%\")\n",
    "    print(f\"MRR: {mrr:.4f}\")\n",
    "    \n",
    "    return {\"recall@1\": recall_at_1, \"recall@5\": recall_at_5, \"mrr\": mrr}\n",
    "\n",
    "clip_results = evaluate_clip_baseline()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. BLIP Baseline: Image Captioning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from transformers import BlipProcessor, BlipForConditionalGeneration\n",
    "from nltk.translate.bleu_score import corpus_bleu, SmoothingFunction\n",
    "from nltk.translate.meteor_score import meteor_score as nltk_meteor\n",
    "from rouge_score import rouge_scorer\n",
    "from bert_score import score as bert_score_fn\n",
    "\n",
    "def evaluate_blip_baseline():\n",
    "    processor = BlipProcessor.from_pretrained(\"Salesforce/blip-image-captioning-base\")\n",
    "    model = BlipForConditionalGeneration.from_pretrained(\n",
    "        \"Salesforce/blip-image-captioning-base\", torch_dtype=torch.float16 if device == \"cuda\" else torch.float32\n",
    "    ).to(device)\n",
    "    model.eval()\n",
    "\n",
    "    print(\"Loading Flickr30K dataset...\")\n",
    "    ds = load_dataset(\"nlphuji/flickr30k\", split=\"test\", trust_remote_code=True)\n",
    "    num_images = len(ds)\n",
    "    \n",
    "    all_reference_captions = []\n",
    "    for i in range(num_images):\n",
    "        cap_field = ds[i][\"caption\"]\n",
    "        cap_list = json.loads(cap_field) if isinstance(cap_field, str) else cap_field\n",
    "        all_reference_captions.append(cap_list)\n",
    "\n",
    "    generated_captions = []\n",
    "    print(\"Generating captions...\")\n",
    "    batch_size = 64\n",
    "    for start in tqdm(range(0, num_images, batch_size)):\n",
    "        end = min(start + batch_size, num_images)\n",
    "        batch_images = [ds[j][\"image\"].convert(\"RGB\") for j in range(start, end)]\n",
    "        inputs = processor(images=batch_images, return_tensors=\"pt\", padding=True).to(device)\n",
    "        with torch.no_grad():\n",
    "            out = model.generate(**inputs, max_new_tokens=50)\n",
    "        for j in range(end - start):\n",
    "            gen_cap = processor.decode(out[j], skip_special_tokens=True).strip()\n",
    "            generated_captions.append(gen_cap)\n",
    "\n",
    "    print(\"Computing metrics...\")\n",
    "    \n",
    "    refs_tokenized = [[nltk.word_tokenize(ref.lower()) for ref in refs] for refs in all_reference_captions]\n",
    "    hyps_tokenized = [nltk.word_tokenize(gen.lower()) for gen in generated_captions]\n",
    "    smooth = SmoothingFunction().method1\n",
    "    bleu4 = corpus_bleu(refs_tokenized, hyps_tokenized, smoothing_function=smooth)\n",
    "\n",
    "    scorer = rouge_scorer.RougeScorer([\"rougeL\"], use_stemmer=True)\n",
    "    rouge_scores = [max(scorer.score(ref, gen)[\"rougeL\"].fmeasure for ref in refs) \n",
    "                    for gen, refs in zip(generated_captions, all_reference_captions)]\n",
    "    rouge_l = np.mean(rouge_scores)\n",
    "\n",
    "    meteor_scores = []\n",
    "    for gen, refs in zip(generated_captions, all_reference_captions):\n",
    "        gen_tok = nltk.word_tokenize(gen.lower())\n",
    "        ref_toks = [nltk.word_tokenize(ref.lower()) for ref in refs]\n",
    "        meteor_scores.append(nltk_meteor(ref_toks, gen_tok))\n",
    "    meteor = np.mean(meteor_scores)\n",
    "\n",
    "    print(\"Computing BERTScore...\")\n",
    "    first_refs = [refs[0] for refs in all_reference_captions]\n",
    "    P, R, F1 = bert_score_fn(generated_captions, first_refs, lang=\"en\", device=device)\n",
    "    bert_score_val = F1.mean().item()\n",
    "\n",
    "    print(f\"\\n=== BLIP Captioning Results ===\")\n",
    "    print(f\"BLEU-4: {bleu4:.4f}\")\n",
    "    print(f\"ROUGE-L: {rouge_l:.4f}\")\n",
    "    print(f\"METEOR: {meteor:.4f}\")\n",
    "    print(f\"BERTScore F1: {bert_score_val:.4f}\")\n",
    "    \n",
    "    return {\"bleu4\": bleu4, \"rouge_l\": rouge_l, \"meteor\": meteor, \"bert_score\": bert_score_val}\n",
    "\n",
    "blip_results = evaluate_blip_baseline()"
   ]
  }\n",
  {
